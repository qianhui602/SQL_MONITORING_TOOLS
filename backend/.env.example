# ============================================
# SQL 监控平台 - 环境配置模板
# ============================================
# 使用方式：
#   1. 复制此文件为 .env
#   2. 修改各配置项为实际值
#   3. 切勿将 .env 提交到版本控制
# ============================================

# ---------- 项目基础信息 ----------
PROJECT_NAME=SQL 监控平台
DEBUG=false
CORS_ORIGINS=["http://localhost:3000"]

# ---------- PostgreSQL（存储监控数据和配置） ----------
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_pg_password_here
PG_DATABASE=sql_monitor

# ---------- SQL Server（被监控的目标数据库，默认实例） ----------
MSSQL_HOST=127.0.0.1
MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASSWORD=your_mssql_password_here
MSSQL_DATABASE=master

# ---------- 定时任务 ----------
SCHEDULER_INTERVAL_SECONDS=60

# ---------- 日志 ----------
LOG_LEVEL=INFO
